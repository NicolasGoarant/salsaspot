<%# app/views/pages/contact.html.erb %>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Contact - SalsaSpot</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Righteous&display=swap" rel="stylesheet">

  <style>
    :root {
      --primary: #ff6b35;
      --primary-glow: rgba(255, 107, 53, 0.3);
      --secondary: #f7931e;
      --bg-light: #fafafa;
      --bg-card: #ffffff;
      --bg-elevated: #f5f5f5;
      --text-primary: #1a1a1a;
      --text-secondary: #666666;
      --border: rgba(0, 0, 0, 0.1);
      --shadow: rgba(0, 0, 0, 0.08);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--bg-light);
      color: var(--text-primary);
      line-height: 1.6;
    }

    /* NAVBAR */
    .navbar {
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 8px var(--shadow);
      position: relative;
      z-index: 100;
    }

    .navbar-brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
    }

    .logo {
      font-family: 'Righteous', sans-serif;
      font-size: 1.75rem;
      letter-spacing: 0.05em;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .tagline {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }

    .tagline br { display: none; }

    .navbar-actions {
      display: flex;
      gap: 0.75rem;
      align-items: center;
    }

    .nav-link {
      background: rgba(46, 125, 50, 0.1);
      color: #2e7d32;
      border: 1px solid rgba(46, 125, 50, 0.3);
      padding: 0.625rem 1.25rem;
      border-radius: 2rem;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9375rem;
      transition: all 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
    }

    .nav-link:hover {
      background: #2e7d32;
      color: white;
      border-color: #2e7d32;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(46, 125, 50, 0.3);
    }

    .nav-link.active {
      background: #2e7d32;
      color: white;
      border-color: #2e7d32;
    }

    .navbar-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      text-decoration: none;
      border-radius: 2rem;
      font-weight: 600;
      transition: all 0.3s;
      box-shadow: 0 4px 12px var(--primary-glow);
    }

    .navbar-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px var(--primary-glow);
    }

    /* BURGER MENU */
    .burger-menu {
      display: none;
      flex-direction: column;
      gap: 4px;
      cursor: pointer;
      padding: 0.5rem;
      background: none;
      border: none;
    }

    .burger-menu span {
      width: 24px;
      height: 3px;
      background: var(--primary);
      border-radius: 2px;
      transition: all 0.3s;
    }

    .burger-menu.active span:nth-child(1) {
      transform: rotate(45deg) translate(6px, 6px);
    }

    .burger-menu.active span:nth-child(2) {
      opacity: 0;
    }

    .burger-menu.active span:nth-child(3) {
      transform: rotate(-45deg) translate(6px, -6px);
    }

    /* Menu mobile */
    .mobile-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 4px 12px var(--shadow);
      z-index: 1000;
      animation: slideDown 0.3s ease-out;
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .mobile-menu.active {
      display: block;
    }

    .mobile-menu-content {
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .mobile-menu-link {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.875rem 1rem;
      background: var(--bg-elevated);
      border-radius: 0.75rem;
      text-decoration: none;
      color: var(--text-primary);
      font-weight: 500;
      font-size: 0.9375rem;
      transition: all 0.2s;
      border: 1px solid transparent;
    }

    .mobile-menu-link:hover {
      background: white;
      border-color: var(--primary);
      transform: translateX(4px);
    }

    .mobile-menu-link.active {
      background: #2e7d32;
      color: white;
    }

    .mobile-menu-link.primary {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      box-shadow: 0 2px 8px var(--primary-glow);
    }

    /* CONTAINER */
    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 3rem 2rem;
    }

    h1 {
      font-family: 'Righteous', sans-serif;
      font-size: 2.5rem;
      color: var(--primary);
      margin-bottom: 1rem;
    }

    .subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      margin-bottom: 3rem;
    }

    h2 {
      font-size: 1.5rem;
      font-weight: 600;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      color: var(--text-primary);
    }

    p {
      margin-bottom: 1rem;
      color: var(--text-secondary);
    }

    .contact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1.5rem;
      margin: 3rem 0;
    }

    .contact-card {
      background: var(--bg-card);
      border-radius: 1rem;
      padding: 1.5rem;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
      text-align: center;
      transition: transform 0.3s;
    }

    .contact-card:hover {
      transform: translateY(-4px);
    }

    .contact-icon {
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
    }

    .contact-card h3 {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .contact-card p {
      font-size: 0.8125rem;
      margin-bottom: 0.75rem;
    }

    .contact-card a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      transition: opacity 0.2s;
      font-size: 0.875rem;
      word-break: break-word;
      display: block;
    }

    .contact-card a:hover {
      opacity: 0.7;
    }

    .faq-section {
      background: var(--bg-card);
      border-radius: 1rem;
      padding: 2rem;
      margin: 2rem 0;
    }

    .faq-item {
      margin-bottom: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }

    .faq-item:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .faq-question {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.125rem;
    }

    .faq-answer {
      color: var(--text-secondary);
    }

    .info-section {
      margin-top: 3rem;
      padding: 1.5rem;
      background: rgba(255, 107, 53, 0.1);
      border-radius: 1rem;
      text-align: center;
    }

    .info-section p {
      margin: 0;
    }

    .info-section .highlight {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--primary);
      margin-bottom: 0.5rem;
    }

    /* RESPONSIVE */
    @media (max-width: 640px) {
      .navbar {
        padding: 0.75rem 1rem;
      }

      .navbar-brand {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.15rem;
      }

      .tagline {
        display: block;
        font-size: 0.75rem;
        line-height: 1.3;
      }

      .tagline br { display: block; }

      .logo { font-size: 1.4rem; }

      .navbar-actions { display: none; }
      .burger-menu { display: flex; }

      .container {
        padding: 2rem 1rem;
      }

      h1 {
        font-size: 2rem;
      }

      .contact-grid {
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .contact-card {
        padding: 1.25rem 1rem;
      }

      .contact-icon {
        font-size: 2rem;
      }

      .contact-card h3 {
        font-size: 1rem;
      }
    }
  </style>
</head>
<body>
  <!-- NAVBAR -->
  <nav class="navbar">
    <%= link_to root_path, class: "navbar-brand" do %>
      <div class="logo">SalsaSpot</div>
      <span class="tagline">La plateforme des soirées<br>salsa, bachata, kizomba</span>
    <% end %>

    <!-- Menu desktop -->
    <div class="navbar-actions">
      <%= link_to about_path, class: "nav-link" do %>
        💃 À propos
      <% end %>
      <%= link_to contact_path, class: "nav-link active" do %>
        📧 Contact
      <% end %>
      <%= link_to new_event_path, class: "navbar-cta" do %>
        ➕ Ajouter une soirée
      <% end %>
    </div>

    <!-- Burger mobile -->
    <button class="burger-menu" id="burger-btn">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- Menu mobile déroulant -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-content">
      <%= link_to root_path, class: "mobile-menu-link" do %>
        <span style="font-size: 1.5rem;">🏠</span>
        <span>Accueil</span>
      <% end %>
      <%= link_to about_path, class: "mobile-menu-link" do %>
        <span style="font-size: 1.5rem;">ℹ️</span>
        <span>À propos</span>
      <% end %>
      <%= link_to contact_path, class: "mobile-menu-link active" do %>
        <span style="font-size: 1.5rem;">📧</span>
        <span>Contact</span>
      <% end %>
      <%= link_to new_event_path, class: "mobile-menu-link primary" do %>
        <span style="font-size: 1.5rem;">➕</span>
        <span>Ajouter une soirée</span>
      <% end %>
    </div>
  </div>

  <div class="container">
    <h1>Contact</h1>
    <p class="subtitle">Une question ? Un événement à ajouter ? N'hésitez pas à nous contacter !</p>

    <div class="contact-grid">
      <div class="contact-card">
        <div class="contact-icon">📧</div>
        <h3>Email</h3>
        <p>Pour toute demande générale</p>
        <a href="mailto:Nicolas.Goarant@hotmail.fr">Nicolas.Goarant@hotmail.fr</a>
      </div>

      <div class="contact-card">
        <div class="contact-icon">📞</div>
        <h3>Téléphone</h3>
        <p>Pour nous joindre directement</p>
        <a href="tel:+33667063179">06 67 06 31 79</a>
      </div>

      <div class="contact-card">
        <div class="contact-icon">🎉</div>
        <h3>Organisateurs</h3>
        <p>Ajouter votre événement</p>
        <%= link_to "Publier une soirée", new_event_path %>
      </div>

      <div class="contact-card">
        <div class="contact-icon">🐛</div>
        <h3>Signaler un bug</h3>
        <p>Problème technique</p>
        <a href="mailto:Nicolas.Goarant@hotmail.fr?subject=Bug SalsaSpot">Nous informer</a>
      </div>
    </div>

    <h2>❓ Questions fréquentes</h2>

    <div class="faq-section">
      <div class="faq-item">
        <div class="faq-question">Comment ajouter mon événement ?</div>
        <div class="faq-answer">
          Cliquez sur le bouton "➕ Ajouter une soirée" en haut à droite. Remplissez le formulaire avec les informations de votre événement. Votre soirée sera publiée après validation.
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">SalsaSpot est-il gratuit ?</div>
        <div class="faq-answer">
          Oui, SalsaSpot est 100% gratuit pour les utilisateurs et les organisateurs. Nous ne prenons aucune commission sur les événements.
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">Comment modifier ou supprimer mon événement ?</div>
        <div class="faq-answer">
          Contactez-nous à Nicolas.Goarant@hotmail.fr ou au 06 67 06 31 79 avec le lien de votre événement. Nous effectuerons les modifications dans les plus brefs délais.
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">Les événements sont-ils vérifiés ?</div>
        <div class="faq-answer">
          Oui, nous vérifions chaque événement avant publication. Nous nous réservons le droit de refuser ou supprimer tout contenu inapproprié.
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">Comment signaler une erreur ?</div>
        <div class="faq-answer">
          Envoyez-nous un email à Nicolas.Goarant@hotmail.fr en précisant le nom de l'événement et la nature de l'erreur. Nous corrigerons rapidement.
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">Puis-je proposer une amélioration ?</div>
        <div class="faq-answer">
          Absolument ! Nous sommes toujours à l'écoute de vos suggestions pour améliorer SalsaSpot. Contactez-nous par email ou téléphone.
        </div>
      </div>
    </div>

    <h2>📍 Nous trouver</h2>
    <p><strong>SalsaSpot</strong></p>
    <p>Nancy, Grand Est, France</p>
    <p>Email : Nicolas.Goarant@hotmail.fr</p>
    <p>Tél : 06 67 06 31 79</p>

    <div class="info-section">
      <p class="highlight">💃 Rejoins la communauté latino ! 🕺</p>
      <p>Suis-nous sur les réseaux sociaux pour ne rien rater des soirées près de chez toi.</p>
    </div>
  </div>

  <script>
    // Burger menu mobile
    const burgerBtn = document.getElementById('burger-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (burgerBtn) {
      burgerBtn.addEventListener('click', () => {
        burgerBtn.classList.toggle('active');
        mobileMenu.classList.toggle('active');
      });

      // Fermer le menu si on clique sur un lien
      document.querySelectorAll('.mobile-menu-link').forEach(link => {
        link.addEventListener('click', () => {
          burgerBtn.classList.remove('active');
          mobileMenu.classList.remove('active');
        });
      });
    }
  </script>
</body>
</html>
