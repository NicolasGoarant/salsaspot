<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Admin - <%= @event.title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Righteous&display=swap" rel="stylesheet">
  <style>
    :root { --primary: #ff6b35; --danger: #d32f2f; --success: #2e7d32; --bg-light: #f5f5f5; --bg-card: #fff; --text-primary: #1a1a1a; --text-secondary: #666; --border: #e0e0e0; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Poppins', sans-serif; background: var(--bg-light); color: var(--text-primary); line-height: 1.6; }
    .navbar { background: var(--bg-card); border-bottom: 1px solid var(--border); padding: 1rem 2rem; }
    .logo { font-family: 'Righteous', sans-serif; font-size: 1.5rem; color: var(--primary); text-decoration: none; }
    .logo span { background: var(--danger); color: white; font-size: 0.75rem; padding: 0.25rem 0.5rem; border-radius: 4px; margin-left: 0.5rem; }
    .container { max-width: 900px; margin: 0 auto; padding: 2rem; }
    .back-link { color: var(--text-secondary); text-decoration: none; margin-bottom: 1.5rem; display: inline-block; }
    .back-link:hover { color: var(--primary); }
    .card { background: var(--bg-card); border-radius: 1rem; border: 1px solid var(--border); overflow: hidden; }
    .card-header { padding: 1.5rem 2rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem; }
    .card-header h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; margin-right: 0.5rem; }
    .badge-salsa { background: rgba(255, 107, 53, 0.1); color: var(--primary); }
    .badge-bachata { background: rgba(233, 30, 99, 0.1); color: #e91e63; }
    .badge-kizomba { background: rgba(156, 39, 176, 0.1); color: #9c27b0; }
    .badge-active { background: rgba(46, 125, 50, 0.1); color: var(--success); }
    .badge-inactive { background: rgba(211, 47, 47, 0.1); color: var(--danger); }
    .actions { display: flex; gap: 0.5rem; }
    .btn { padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 500; text-decoration: none; border: none; cursor: pointer; }
    .btn-primary { background: var(--primary); color: white; }
    .btn-danger { background: var(--danger); color: white; }
    .card-body { padding: 2rem; }
    .info-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .info-item { margin-bottom: 1rem; }
    .info-label { font-size: 0.75rem; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 0.25rem; }
    .info-value { font-size: 1rem; font-weight: 500; }
    .info-value.highlight { color: var(--primary); font-size: 1.25rem; }
    .description { grid-column: span 2; padding: 1rem; background: var(--bg-light); border-radius: 0.5rem; }
    @media (max-width: 768px) { .info-grid { grid-template-columns: 1fr; } .description { grid-column: span 1; } }
  </style>
</head>
<body>
  <nav class="navbar">
    <%= link_to root_path, class: "logo" do %>SalsaSpot <span>Admin</span><% end %>
  </nav>
  <div class="container">
    <%= link_to "← Retour à la liste", admin_events_path, class: "back-link" %>
    <div class="card">
      <div class="card-header">
        <div>
          <h1><%= @event.title %></h1>
          <div>
            <% @event.dance_styles&.each do |style| %>
              <span class="badge badge-<%= style %>"><%= style %></span>
            <% end %>
            <span class="badge badge-<%= @event.is_active ? 'active' : 'inactive' %>"><%= @event.is_active ? '✓ Actif' : '✗ Inactif' %></span>
          </div>
        </div>
        <div class="actions">
          <%= link_to "✏️ Modifier", edit_admin_event_path(@event), class: "btn btn-primary" %>
          <%= button_to "🗑️ Supprimer", admin_event_path(@event), method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Êtes-vous sûr ?" } %>
        </div>
      </div>
      <div class="card-body">
        <div class="info-grid">
          <div class="info-item"><div class="info-label">📍 Lieu</div><div class="info-value"><%= @event.venue_name %></div></div>
          <div class="info-item"><div class="info-label">🏙️ Ville</div><div class="info-value"><%= @event.city %></div></div>
          <div class="info-item"><div class="info-label">📅 Date</div><div class="info-value"><%= @event.starts_at.strftime("%d/%m/%Y à %H:%M") %></div></div>
          <div class="info-item"><div class="info-label">💰 Prix</div><div class="info-value highlight"><%= @event.price && @event.price > 0 ? "#{@event.price}€" : "Gratuit" %></div></div>
          <div class="info-item"><div class="info-label">📍 Adresse</div><div class="info-value"><%= @event.address %></div></div>
          <div class="info-item"><div class="info-label">🎓 Niveau</div><div class="info-value"><%= @event.level || "Tous niveaux" %></div></div>
          <% if @event.description.present? %>
            <div class="description"><div class="info-label">📝 Description</div><p><%= @event.description %></p></div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
