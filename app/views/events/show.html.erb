<%# app/views/events/show.html.erb %>
<%
  og_title = @event.title
  og_description = @event.description.present? ? truncate(strip_tags(@event.description), length: 160) : "#{@event.dance_styles&.map(&:capitalize)&.join(', ')} — #{l(@event.starts_at, format: '%A %d %B %Y')} à #{@event.city}"
  og_image = @event.og_photo_url
  default_style = (@event.dance_styles & ['salsa', 'bachata', 'kizomba']).first || 'salsa'
%>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title><%= @event.title %> - SalsaSpot</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= og_description %>">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Open Graph -->
  <meta property="og:type" content="event">
  <meta property="og:title" content="<%= og_title %> - SalsaSpot">
  <meta property="og:description" content="<%= og_description %>">
  <meta property="og:url" content="<%= request.original_url %>">
  <% if og_image %>
    <meta property="og:image" content="<%= og_image %>">
  <% else %>
    <meta property="og:image" content="<%= asset_url("#{default_style}.jpg") %>">
  <% end %>
  <meta property="og:locale" content="fr_FR">
  <meta property="og:site_name" content="SalsaSpot">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= og_title %> - SalsaSpot">
  <meta name="twitter:description" content="<%= og_description %>">
  <% if og_image %>
    <meta name="twitter:image" content="<%= og_image %>">
  <% end %>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Righteous&display=swap" rel="stylesheet">

  <style>
    :root {
      --primary: #ff6b35;
      --primary-glow: rgba(255, 107, 53, 0.3);
      --secondary: #f7931e;
      --bg-light: #fafafa;
      --bg-card: #ffffff;
      --bg-elevated: #f5f5f5;
      --text-primary: #1a1a1a;
      --text-secondary: #666666;
      --border: rgba(0, 0, 0, 0.1);
      --shadow: rgba(0, 0, 0, 0.08);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100%;
      overflow-x: hidden;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--bg-light);
      color: var(--text-primary);
    }

    /* ===================== NAVBAR ===================== */
    .navbar {
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 8px var(--shadow);
    }

    .navbar-brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
    }

    .logo {
      font-family: 'Righteous', sans-serif;
      font-size: 1.75rem;
      letter-spacing: 0.05em;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .back-link {
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: var(--primary);
    }

    /* ===================== CONTAINER ===================== */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
      width: 100%;
      overflow-x: hidden;
    }

    /* ===================== EVENT HEADER ===================== */
    .event-header {
      background: var(--bg-card);
      border-radius: 1.5rem;
      padding: 2.5rem;
      margin-bottom: 2rem;
      box-shadow: 0 4px 16px var(--shadow);
      border-top: 4px solid var(--primary);
      width: 100%;
      overflow: hidden;
    }

    .event-photo-container {
      width: 100%;
      height: 350px;
      overflow: hidden;
      border-radius: 1rem;
      margin-bottom: 2rem;
      background-size: cover;
      background-position: center;
    }

    .event-title {
      font-family: 'Righteous', sans-serif;
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
      letter-spacing: 0.02em;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .event-meta {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
      font-size: 1rem;
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
    }

    .event-meta-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .event-badges {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .badge {
      padding: 0.5rem 1rem;
      border-radius: 2rem;
      font-size: 0.875rem;
      font-weight: 600;
    }

    .badge-style {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
    }

    .badge-lessons {
      background: #fff3e0;
      color: #e65100;
      border: 1px solid #ffcc80;
    }

    /* ===================== GRID ===================== */
    .grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 2rem;
      margin-bottom: 2rem;
      width: 100%;
    }

    /* ===================== SECTION ===================== */
    .section {
      background: var(--bg-card);
      border-radius: 1.5rem;
      padding: 2rem;
      box-shadow: 0 4px 16px var(--shadow);
      margin-bottom: 2rem;
      width: 100%;
      overflow: hidden;
    }

    .section h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
    }

    .section p {
      line-height: 1.6;
      color: var(--text-secondary);
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .info-list {
      list-style: none;
    }

    .info-list li {
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: var(--text-secondary);
    }

    .info-list li:last-child {
      border-bottom: none;
    }

    .info-list strong {
      color: var(--text-primary);
      min-width: 100px;
      flex-shrink: 0;
    }

    .info-list a {
      color: var(--primary);
      text-decoration: none;
      word-break: break-all;
    }

    .info-list a:hover {
      text-decoration: underline;
    }

    /* ===================== MAP ===================== */
    #map {
      height: 300px;
      border-radius: 1rem;
      margin-top: 1.5rem;
    }

    /* ===================== SIMILAR EVENTS ===================== */
    .similar-events {
      display: grid;
      gap: 1rem;
    }

    .similar-card {
      background: var(--bg-elevated);
      padding: 1.5rem;
      border-radius: 1rem;
      transition: all 0.3s;
      text-decoration: none;
      color: inherit;
      border: 1px solid var(--border);
    }

    .similar-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px var(--shadow);
      border-color: var(--primary);
    }

    .similar-card h3 {
      font-size: 1.125rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .similar-card p {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .similar-price {
      color: var(--primary);
      font-weight: 700;
      font-size: 1.125rem;
    }

    /* ===================== CTA BUTTON ===================== */
    .cta-button {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem 2rem;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      text-decoration: none;
      border-radius: 3rem;
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.3s;
      box-shadow: 0 4px 12px var(--primary-glow);
      margin-top: 1.5rem;
    }

    .cta-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px var(--primary-glow);
    }

    .event-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: center;
      margin-top: 1.5rem;
    }

    .event-actions .cta-button {
      margin-top: 0;
    }

    .gcal-button {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem 1.75rem;
      background: white;
      color: var(--text-primary);
      text-decoration: none;
      border-radius: 3rem;
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.3s;
      border: 2px solid var(--border);
    }

    .gcal-button:hover {
      border-color: #4285f4;
      color: #4285f4;
      box-shadow: 0 4px 12px rgba(66, 133, 244, 0.2);
      transform: translateY(-2px);
    }

    .gcal-button img {
      width: 18px;
      height: 18px;
    }

    /* ===================== RESPONSIVE ===================== */
    @media (max-width: 960px) {
      .grid {
        grid-template-columns: 1fr;
      }

      .event-photo-container {
        height: 220px;
      }

      .container {
        padding: 1rem;
      }

      .event-header {
        padding: 1.5rem;
      }

      .event-title {
        font-size: 1.75rem;
      }

      .event-meta {
        gap: 1rem;
        font-size: 0.9rem;
      }

      .section {
        padding: 1.25rem;
      }

      .event-actions {
        flex-direction: column;
      }

      .event-actions .cta-button,
      .event-actions .gcal-button {
        width: 100%;
        justify-content: center;
      }

      .section h2 {
        font-size: 1.25rem;
        margin-bottom: 1rem;
      }

      .navbar {
        padding: 1rem;
      }

      .logo {
        font-size: 1.5rem;
      }

      #map {
        height: 250px;
      }

      .info-list li {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
      }

      .info-list strong {
        min-width: auto;
      }
    }
  </style>
</head>
<body>
  <!-- NAVBAR -->
  <nav class="navbar">
    <%= link_to events_path, class: "navbar-brand" do %>
      <div class="logo">SalsaSpot</div>
    <% end %>
    <%= link_to "← Retour à la carte", events_path, class: "back-link" %>
  </nav>

  <div class="container">
    <!-- EVENT HEADER -->
    <div class="event-header">
      <%# Photo de l'événement %>
      <% if @event.photos.attached? %>
        <div class="event-photo-container" style="background-image: url(<%= @event.photo_url %>);"></div>
      <% else %>
        <div class="event-photo-container" style="background-image: url(<%= asset_path("#{default_style}.jpg") %>);"></div>
      <% end %>

      <h1 class="event-title"><%= @event.title %></h1>

      <div class="event-meta">
        <span class="event-meta-item">
          📅 <%= l(@event.starts_at, format: "%A %d %B %Y à %Hh%M") %>
        </span>
        <span class="event-meta-item">
          📍 <%= [@event.venue_name, @event.city].compact.reject(&:blank?).join(', ') %>
        </span>
        <span class="event-meta-item">
          💰 <%= @event.price_display %>
        </span>
        <% if @event.level.present? %>
          <span class="event-meta-item">
            <%= @event.level == 'tous' ? '⚪️' : @event.level == 'debutant' ? '🟢' : @event.level == 'intermediaire' ? '🟡' : '🔴' %>
            <%= @event.level&.capitalize %>
          </span>
        <% end %>
      </div>

      <div class="event-badges">
        <% @event.dance_styles&.each do |style| %>
          <span class="badge badge-style"><%= style.capitalize %></span>
        <% end %>
        <% if @event.has_lessons %>
          <span class="badge badge-lessons">📚 Cours inclus<%= @event.lessons_time.present? ? " à #{@event.lessons_time}" : "" %></span>
        <% end %>
      </div>
    </div>

    <!-- GRID CONTENT -->
    <div class="grid">
      <!-- LEFT COLUMN -->
      <div>
        <% if @event.description.present? %>
          <div class="section">
            <h2>📝 Description</h2>
            <%= simple_format(@event.description) %>
          </div>
        <% end %>

        <div class="section">
          <h2>📍 Lieu</h2>
          <p><strong><%= @event.venue_name %></strong></p>
          <% if @event.address.present? %>
            <p><%= @event.address %></p>
          <% end %>
          <p><%= [@event.postal_code, @event.city].compact.join(' ') %></p>

          <% if @event.latitude.present? && @event.longitude.present? %>
            <div id="map"></div>
          <% end %>
        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div>
        <div class="section">
          <h2>ℹ️ Infos pratiques</h2>
          <ul class="info-list">
            <% if @event.organizer_name.present? %>
              <li>
                <strong>Organisateur :</strong>
                <%= @event.organizer_name %>
              </li>
            <% end %>

            <% if @event.phone.present? %>
              <li>
                <strong>Téléphone :</strong>
                <%= link_to @event.phone, "tel:#{@event.phone.gsub(' ', '')}" %>
              </li>
            <% end %>

            <% if @event.organizer_email.present? %>
              <li>
                <strong>Email :</strong>
                <%= mail_to @event.organizer_email %>
              </li>
            <% end %>

            <% if @event.website.present? %>
              <li>
                <strong>Site web :</strong>
                <%= link_to "Visiter", @event.website, target: "_blank" %>
              </li>
            <% end %>

            <% if @event.facebook_url.present? %>
              <li>
                <strong>Facebook :</strong>
                <%= link_to "Voir l'événement", @event.facebook_url, target: "_blank" %>
              </li>
            <% end %>
          </ul>

          <div class="event-actions">
            <% if @event.facebook_url.present? || @event.website.present? %>
              <%= link_to "Réserver ma place →", @event.website.presence || @event.facebook_url, class: "cta-button", target: "_blank" %>
            <% end %>

            <%
              gcal_start = @event.starts_at.strftime('%Y%m%dT%H%M%S')
              gcal_end = (@event.ends_at || @event.starts_at + 3.hours).strftime('%Y%m%dT%H%M%S')
              gcal_title = CGI.escape(@event.title)
              gcal_location = CGI.escape([@event.venue_name, @event.address, @event.city].compact.reject(&:blank?).join(', '))
              gcal_details = CGI.escape(@event.description.to_s.truncate(200))
              gcal_url = "https://calendar.google.com/calendar/event?action=TEMPLATE&text=#{gcal_title}&dates=#{gcal_start}/#{gcal_end}&location=#{gcal_location}&details=#{gcal_details}"
            %>
            <%= link_to gcal_url, class: "gcal-button", target: "_blank" do %>
              <img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Google_Calendar_icon_%282020%29.svg" alt="Google Calendar">
              Ajouter au calendrier
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- SIMILAR EVENTS -->
    <% if @similar_events&.any? %>
      <div class="section">
        <h2>🔥 Autres soirées à <%= @event.city %></h2>
        <div class="similar-events">
          <% @similar_events.each do |similar| %>
            <%= link_to event_path(similar), class: "similar-card" do %>
              <h3><%= similar.title %></h3>
              <p>
                📅 <%= similar.starts_at.strftime("%d/%m à %Hh%M") %> •
                <%= similar.dance_styles&.map(&:capitalize)&.join(', ') %>
              </p>
              <span class="similar-price"><%= similar.price_display %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  <% if @event.latitude.present? && @event.longitude.present? %>
    const map = L.map('map').setView([<%= @event.latitude %>, <%= @event.longitude %>], 15);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      attribution: '© OpenStreetMap, © CartoDB'
    }).addTo(map);

    <% marker_color = (@event.is_free || (@event.price && @event.price == 0)) ? '#4CAF50' : '#ff6b35' %>
    const color = '<%= marker_color %>';

    <%
      styles = @event.dance_styles || []
      emoji = if styles.include?('salsa')
        '💃'
      elsif styles.include?('bachata')
        '🕺'
      elsif styles.include?('kizomba')
        '❤️'
      else
        '🎵'
      end
    %>
    const emoji = '<%= emoji %>';

    const icon = L.divIcon({
      html: '<div style="background: ' + color + '; color: white; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 24px; box-shadow: 0 4px 16px rgba(0,0,0,0.25); border: 3px solid white;">' + emoji + '</div>',
      className: '',
      iconSize: [50, 50],
      iconAnchor: [25, 50]
    });

    L.marker([<%= @event.latitude %>, <%= @event.longitude %>], { icon }).addTo(map);
  <% end %>
</script>
</body>
</html>
