<%# app/views/events/merci.html.erb %>
<style>
  .merci-page {
    max-width: 600px;
    margin: 0 auto;
    padding: 5rem 2rem;
    text-align: center;
  }

  .merci-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    animation: bounce-in 0.6s ease-out;
  }

  @keyframes bounce-in {
    0% { transform: scale(0); opacity: 0; }
    60% { transform: scale(1.2); }
    100% { transform: scale(1); opacity: 1; }
  }

  .merci-page h1 {
    font-family: 'Bebas Neue', 'DM Sans', sans-serif;
    font-size: 3rem;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    color: #1a1a1a;
  }

  .merci-page p {
    font-size: 1.15rem;
    color: #666;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .merci-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 1.25rem;
    padding: 2.5rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    margin-bottom: 2rem;
  }

  .merci-steps {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .merci-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    max-width: 140px;
  }

  .merci-step-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
  }

  .merci-step:nth-child(1) .merci-step-icon { background: #ff6b35; }
  .merci-step:nth-child(2) .merci-step-icon { background: #f7931e; }
  .merci-step:nth-child(3) .merci-step-icon { background: #4CAF50; }

  .merci-step span {
    font-size: 0.875rem;
    color: #666;
    text-align: center;
    line-height: 1.4;
  }

  .merci-btn {
    display: inline-block;
    background: linear-gradient(135deg, #ff6b35, #f7931e);
    color: white;
    padding: 1rem 2.5rem;
    border-radius: 0.75rem;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.05rem;
    transition: all 0.2s;
    box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
  }

  .merci-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
    color: white;
  }

  .merci-add-link {
    display: inline-block;
    margin-top: 1rem;
    color: #666;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .merci-add-link:hover {
    color: #ff6b35;
  }

  @media (max-width: 640px) {
    .merci-page {
      padding: 3rem 1rem;
    }

    .merci-page h1 {
      font-size: 2.25rem;
    }

    .merci-steps {
      gap: 1.5rem;
    }
  }
</style>

<div class="merci-page">
  <div class="merci-card">
    <div class="merci-icon">🎉</div>
    <h1>Merci !</h1>
    <p>
      Ta soirée a bien été soumise.<br>
      Elle sera visible sur SalsaSpot après vérification.
    </p>

    <div class="merci-steps">
      <div class="merci-step">
        <div class="merci-step-icon">1</div>
        <span>Soirée envoyée</span>
      </div>
      <div class="merci-step">
        <div class="merci-step-icon">2</div>
        <span>Vérification en cours</span>
      </div>
      <div class="merci-step">
        <div class="merci-step-icon">3</div>
        <span>En ligne !</span>
      </div>
    </div>
  </div>

  <%= link_to "Retour à la carte", root_path, class: "merci-btn" %>
  <br>
  <%= link_to "Ajouter une autre soirée →", new_event_path, class: "merci-add-link" %>
</div>
