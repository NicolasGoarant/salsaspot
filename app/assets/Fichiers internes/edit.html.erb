<%# app/views/admin/events/edit.html.erb %>
<% content_for(:admin_title) { "Admin - Modifier #{@event.title}" } %>

<div class="container-narrow">
  <%= link_to "← Retour à la liste", admin_events_path, class: "back-link" %>

  <div class="card-padded">
    <h1 style="font-size: 1.5rem; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border);">
      ✏️ Modifier l'événement
    </h1>

    <%= form_with model: @event, url: admin_event_path(@event), method: :patch, local: true do |f| %>
      <%= render 'form', f: f %>

      <div class="form-actions">
        <%= link_to "Annuler", admin_events_path, class: "btn btn-secondary" %>
        <%= f.submit "💾 Enregistrer", class: "btn btn-lg btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
