<%# app/views/admin/events/show.html.erb %>
<% content_for(:admin_title) { "Admin - #{@event.title}" } %>

<div class="container-medium">
  <%= link_to "← Retour à la liste", admin_events_path, class: "back-link" %>

  <div class="card">
    <div class="card-header">
      <div>
        <h1 style="font-size: 1.5rem; margin-bottom: 0.5rem;"><%= @event.title %></h1>
        <div>
          <% @event.dance_styles&.each do |style| %>
            <span class="badge badge-<%= style %>"><%= style %></span>
          <% end %>
          <span class="badge badge-<%= @event.is_active ? 'active' : 'inactive' %>">
            <%= @event.is_active ? '✓ Actif' : '✗ Inactif' %>
          </span>
        </div>
      </div>
      <div class="actions">
        <%= link_to "✏️ Modifier", edit_admin_event_path(@event), class: "btn btn-primary" %>
        <%= button_to "🗑️ Supprimer", admin_event_path(@event), method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Êtes-vous sûr ?" } %>
      </div>
    </div>

    <div class="card-body">
      <div class="info-grid">
        <div class="info-item">
          <div class="info-label">📍 Lieu</div>
          <div class="info-value"><%= @event.venue_name %></div>
        </div>
        <div class="info-item">
          <div class="info-label">🏙️ Ville</div>
          <div class="info-value"><%= @event.city %></div>
        </div>
        <div class="info-item">
          <div class="info-label">📅 Date</div>
          <div class="info-value"><%= @event.starts_at.strftime("%d/%m/%Y à %H:%M") %></div>
        </div>
        <div class="info-item">
          <div class="info-label">💰 Prix</div>
          <div class="info-value highlight"><%= @event.price && @event.price > 0 ? "#{@event.price}€" : "Gratuit" %></div>
        </div>
        <div class="info-item">
          <div class="info-label">📍 Adresse</div>
          <div class="info-value"><%= @event.address %></div>
        </div>
        <div class="info-item">
          <div class="info-label">🎓 Niveau</div>
          <div class="info-value"><%= @event.level || "Tous niveaux" %></div>
        </div>
        <% if @event.organizer_name.present? %>
          <div class="info-item">
            <div class="info-label">👤 Organisateur</div>
            <div class="info-value"><%= @event.organizer_name %></div>
          </div>
        <% end %>
        <% if @event.recurrence.present? %>
          <div class="info-item">
            <div class="info-label">🔄 Récurrence</div>
            <div class="info-value"><%= @event.recurrence.capitalize %></div>
          </div>
        <% end %>
        <% if @event.description.present? %>
          <div class="description">
            <div class="info-label">📝 Description</div>
            <p><%= @event.description %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
