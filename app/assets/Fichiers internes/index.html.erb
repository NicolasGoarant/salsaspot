<%# app/views/admin/events/index.html.erb %>
<% content_for(:admin_title) { "Admin - Gestion des événements" } %>

<div class="container">
  <div class="header">
    <h1>📋 Gestion des événements</h1>
    <div style="display: flex; gap: 1rem; align-items: center;">
      <%= link_to "➕ Nouvel événement", new_admin_event_path, class: "btn btn-primary" %>
      <%= link_to "📥 Import Excel", import_admin_events_path, class: "btn btn-secondary" %>
      <div class="stats">
        <div class="stat-card">
          <div class="number"><%= @events.count %></div>
          <div class="label">Total</div>
        </div>
        <div class="stat-card">
          <div class="number"><%= @events.where(is_active: true).count %></div>
          <div class="label">En ligne</div>
        </div>
        <div class="stat-card">
          <div class="number"><%= @events.where(is_active: false).count %></div>
          <div class="label">Brouillons</div>
        </div>
      </div>
    </div>
  </div>

  <div class="tabs">
    <%= link_to admin_events_path, class: "tab #{params[:filter].blank? ? 'active' : ''}" do %>
      Tous <span class="count"><%= @events.count %></span>
    <% end %>
    <%= link_to admin_events_path(filter: 'active'), class: "tab #{params[:filter] == 'active' ? 'active' : ''}" do %>
      ✓ En ligne <span class="count"><%= @events.where(is_active: true).count %></span>
    <% end %>
    <%= link_to admin_events_path(filter: 'draft'), class: "tab #{params[:filter] == 'draft' ? 'active' : ''}" do %>
      📝 Brouillons <span class="count"><%= @events.where(is_active: false).count %></span>
    <% end %>
    <%= link_to admin_events_path(filter: 'upcoming'), class: "tab #{params[:filter] == 'upcoming' ? 'active' : ''}" do %>
      📅 À venir <span class="count"><%= @events.where("starts_at >= ?", Time.current).count %></span>
    <% end %>
  </div>

  <div class="table-container">
    <%
      filtered_events = case params[:filter]
      when 'active'
        @events.where(is_active: true)
      when 'draft'
        @events.where(is_active: false)
      when 'upcoming'
        @events.where("starts_at >= ?", Time.current)
      else
        @events
      end
    %>
    <% if filtered_events.any? %>
      <table>
        <thead>
          <tr>
            <th>Événement</th>
            <th>Styles</th>
            <th>Date</th>
            <th>Prix</th>
            <th>Statut</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% filtered_events.each do |event| %>
            <tr class="<%= event.is_active ? '' : 'draft' %>">
              <td>
                <div class="event-title"><%= event.title %></div>
                <div class="event-city">📍 <%= event.city %></div>
              </td>
              <td>
                <% event.dance_styles&.each do |style| %>
                  <span class="badge badge-<%= style %>"><%= style %></span>
                <% end %>
              </td>
              <td>
                <% if event.starts_at >= Time.current %>
                  <span class="date date-future">📅 <%= event.starts_at.strftime("%d/%m/%Y %H:%M") %></span>
                <% else %>
                  <span class="date date-past"><%= event.starts_at.strftime("%d/%m/%Y %H:%M") %></span>
                <% end %>
              </td>
              <td>
                <% if event.price && event.price > 0 %>
                  <span class="price"><%= event.price %>€</span>
                <% else %>
                  <span class="badge badge-active">Gratuit</span>
                <% end %>
              </td>
              <td>
                <% if event.is_active %>
                  <span class="badge badge-active">✓ En ligne</span>
                <% else %>
                  <span class="badge badge-draft">📝 Brouillon</span>
                <% end %>
              </td>
              <td>
                <div class="actions">
                  <% if event.is_active %>
                    <%= button_to "Dépublier", toggle_admin_event_path(event), method: :patch, class: "btn btn-sm btn-warning" %>
                  <% else %>
                    <%= button_to "✓ Publier", toggle_admin_event_path(event), method: :patch, class: "btn btn-sm btn-success" %>
                  <% end %>
                  <%= link_to "Modifier", edit_admin_event_path(event), class: "btn btn-sm btn-secondary" %>
                  <%= button_to "🗑️", admin_event_path(event), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Supprimer cet événement ?" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state">
        <h3>Aucun événement</h3>
        <p>Il n'y a pas d'événements dans cette catégorie.</p>
      </div>
    <% end %>
  </div>
</div>
